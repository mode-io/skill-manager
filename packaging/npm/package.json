{
  "name": "skill-manager",
  "version": "0.1.0",
  "description": "Public installer wrapper for the skill-manager native release artifact.",
  "license": "MIT",
  "private": false,
  "bin": {
    "skill-manager": "bin/skill-manager.js"
  },
  "scripts": {
    "prepack": "python3 ../../scripts/sync_public_metadata.py --write",
    "postpack": "rm -f LICENSE",
    "postinstall": "node scripts/install.js"
  },
  "files": [
    "LICENSE",
    "bin",
    "scripts"
  ],
  "homepage": "https://github.com/mode-io/skill-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mode-io/skill-manager.git",
    "directory": "packaging/npm"
  },
  "bugs": {
    "url": "https://github.com/mode-io/skill-manager/issues"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ]
}
